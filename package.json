{
  "name": "benefactor-cc-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tests for the benefactor.cc marketing site (built GitHub Pages output).",
  "scripts": {
    "test": "node --test tests/site-contract.test.mjs",
    "test:ui:puppeteer": "node --test --test-concurrency=1 tests/site-puppeteer.test.mjs",
    "test:ui:playwright": "node --test --test-concurrency=1 tests/site-playwright.test.mjs",
    "test:browser": "node --test --test-concurrency=1 tests/site-puppeteer.test.mjs tests/site-playwright.test.mjs",
    "test:all": "npm test && npm run test:browser"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "puppeteer": "^25.2.1"
  }
}
